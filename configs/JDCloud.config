#########################################################################
### [1] 硬件与系统基础 (原 JDCloud.config 完整内容)
#########################################################################
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y

# 雅典娜 LED 控制插件
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="luci-app-athena-led luci-i18n-athena-led-zh-cn"
CONFIG_PACKAGE_luci-app-athena-led=y
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=y

# 内存与固件版本定义
CONFIG_ATH11K_MEM_PROFILE_512M=y
CONFIG_NSS_FIRMWARE_VERSION_12_5=y
CONFIG_PACKAGE_nss-firmware-ipq60xx=y

#########################################################################
### [2] 编译优化与通用设置 (原 General.config 完整内容)
#########################################################################
CONFIG_DEVEL=y
CONFIG_TARGET_OPTIONS=y
CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -march=armv8-a+crypto+crc -mcpu=cortex-a53+crypto+crc -mtune=cortex-a53"
CONFIG_CCACHE=y
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_LUCI_LANG_zh_Hans=y

# --- 进阶 ZRAM 设置 ---
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y
CONFIG_KERNEL_ZRAM_BACKEND_LZO=y
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y

# 如果源码支持，强制使用 GCC 13/14 (通常 ImmortalWrt 默认已跟随)
CONFIG_GCC_VERSION_13=y
# --- 系统工具与维护 ---
CONFIG_PACKAGE_dmesg=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_tune2fs=y
CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_nano-full=y
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_coremark=y
CONFIG_PACKAGE_hdparm=y
CONFIG_PACKAGE_smartmontools-drivedb=y
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_openssh-sftp-server=y

# --- Web 界面与主题插件 ---
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-uhttpd=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-app-usb-printer=y

# --- HomeProxy (Sing-box 核心) ---
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_sing-box=y
CONFIG_SINGBOX_WITH_QUIC=y
CONFIG_SINGBOX_WITH_ECH=y
CONFIG_SINGBOX_WITH_TUIC=y
CONFIG_SINGBOX_WITH_GRPC=y
CONFIG_SINGBOX_WITH_TPROXY=y


# --- 网络依赖与 TUN 模式环境 ---
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_libcap-bin=y
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set

# --- 其它禁用项 ---
# CONFIG_FEED_nss_packages is not set
# CONFIG_FEED_sqm_scripts_nss is not set
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set
# 禁用过时的文件系统支持（如果你不用移动硬盘）
# CONFIG_PACKAGE_kmod-fs-reiserfs is not set
# CONFIG_PACKAGE_kmod-fs-hfs is not set
# 禁用蓝牙支持（这两款机器硬件不支持蓝牙，但源码常默认开启）
# CONFIG_PACKAGE_kmod-bluetooth is not set
# 禁用不需要的虚拟化/容器支持（如果你不用 Docker）
# CONFIG_PACKAGE_kmod-ikconfig is not set
# 禁用红外线支持（硬件没有红外接收器）
# CONFIG_PACKAGE_kmod-ir is not set
# CONFIG_PACKAGE_kmod-sound-core is not set
# CONFIG_PACKAGE_kmod-usb-audio is not set
# CONFIG_PACKAGE_kmod-nfc is not set
# CONFIG_PACKAGE_kmod-hamradio is not set

#########################################################################
### [3] 增补：QCA/NSS 芯片级硬件加速 (确保 6.12 内核性能全开)
#########################################################################
# 强制开启 IRQ 均衡 (多核并发优化，你原本已加)
CONFIG_PACKAGE_irqbalance=y
# 核心硬件加速模块 (解决之前发现的 QCA 条目缺失风险)
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-bridge-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-vlan-mgr=y
CONFIG_PACKAGE_kmod-nft-nat=y

# 指令集深度压榨 LTO 优化 消耗编译机器的内存,导致任务失败。如果报错，请优先关掉这一项
CONFIG_USE_LTO=y

# 开启大文件传输优化 (适用于千兆环境)
CONFIG_TARGET_ROOTFS_PARTSIZE=160
CONFIG_TARGET_KERNEL_PARTSIZE=16
# 强制开启 TCP_BBR (大幅提升科学上网和远端访问速度)
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_DEFAULT_TCP_CONG="bbr"
# 无线驱动增强
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_kmod-ath11k-pci=y